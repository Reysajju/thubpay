# ============================================
# ThubPay Payment Portal - Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# Supabase Configuration
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# Supabase GitHub OAuth
SUPABASE_AUTH_EXTERNAL_GITHUB_REDIRECT_URI="http://127.0.0.1:54321/auth/v1/callback"
SUPABASE_AUTH_EXTERNAL_GITHUB_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GITHUB_SECRET=

# ============================================
# Stripe Configuration
# ============================================
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PLATFORM_ACCOUNT_ID=acct_your_platform_account
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ============================================
# PayPal Configuration
# ============================================
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# ============================================
# Square Configuration
# ============================================
SQUARE_ACCESS_TOKEN=sq0atp-your_access_token
SQUARE_LOCATION_ID=your_location_id

# ============================================
# Braintree Configuration
# ============================================
BRAINTREE_CLIENT_ID=your_braintree_client_id
BRAINTREE_CLIENT_SECRET=your_braintree_client_secret

# ============================================
# Adyen Configuration
# ============================================
ADYEN_API_KEY=your_adyen_api_key

# ============================================
# Razorpay Configuration
# ============================================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ============================================
# Mollie Configuration
# ============================================
MOLLIE_API_KEY=test_xxxxx

# ============================================
# Checkout.com Configuration
# ============================================
CHECKOUT_API_KEY=test_ck_xxxxx

# ============================================
# Verifone Configuration
# ============================================
VERIFONE_API_KEY=your_verifone_api_key

# ============================================
# Email Configuration (Resend)
# ============================================
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=noreply@thubpay.com
EMAIL_FROM_NAME=ThubPay
BILLING_FROM_EMAIL="billing@thubpay.com"

# ============================================
# Slack Configuration
# ============================================
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ============================================
# Redis Configuration (for BullMQ)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# Application Configuration
# ============================================
NEXT_PUBLIC_SITE_URL="https://thubpay.com"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ============================================
# Authentication & Security
# ============================================
JWT_SECRET=your-jwt-secret-min-32-chars
MFA_ISSUER=ThubPay
BCRYPT_COST_FACTOR=12

# ============================================
# Payment Settings
# ============================================
DEFAULT_CURRENCY=usd
DEFAULT_LANGUAGE=en
TIMEZONE=America/New_York
MAX_TRANSACTION_AMOUNT=1000000
MIN_PAYOUT_AMOUNT=10000

# ============================================
# Payment Link Settings
# ============================================
DEFAULT_PAYMENT_LINK_EXPIRY_DAYS=7
DEFAULT_PAYMENT_LINK_MAX_USES=1

# ============================================
# Email Template Settings
# ============================================
EMAIL_FROM_ADDRESS=noreply@thubpay.com
EMAIL_REPLY_TO_ADDRESS=support@thubpay.com

# ============================================
# CDN / Asset Storage
# ============================================
ASSET_STORAGE_URL=https://your-cdn.com/assets
UPLOAD_MAX_SIZE=10485760  # 10MB in bytes

# ============================================
# Monitoring & Analytics
# ============================================
SENTRY_DSN=https://xxx@sentry.io/xxx
AMPLITUDE_KEY=your_amplitude_key
SEGMENT_WRITE_KEY=your_segment_key

# ============================================
# Development Settings
# ============================================
ENABLE_DEBUG=false
LOG_LEVEL=info

# ============================================
# Test Mode Settings
# ============================================
STRIPE_TEST_MODE=true
PAYPAL_SANDBOX_MODE=true
